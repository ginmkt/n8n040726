# ============================================================================
#  Copy file này thành .env  →  cp .env.example .env  →  rồi điền giá trị thật.
#  .env đã nằm trong .gitignore, KHÔNG BAO GIỜ commit nó lên Git.
# ============================================================================

# --- Encryption key (BẮT BUỘC) --------------------------------------------
# Tạo key mới:  openssl rand -hex 32
# QUAN TRỌNG: mất/đổi key này thì mọi credential đã lưu sẽ không giải mã được.
# Lưu 1 bản backup ở password manager (1Password/Bitwarden) hoặc vault,
# đặt TÁCH KHỎI repo này. Dùng CÙNG một key trên mọi server để restore được.
N8N_ENCRYPTION_KEY=doi_bang_ket_qua_cua_openssl_rand_hex_32

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_USER=n8n
POSTGRES_PASSWORD=doi_bang_mat_khau_manh
POSTGRES_DB=n8n

# --- Host / webhook --------------------------------------------------------
# Chạy local thì giữ nguyên. Có domain thì đổi hết sang domain của bạn
# (vd N8N_HOST=n8n.example.com, N8N_PROTOCOL=https,
#      WEBHOOK_URL=https://n8n.example.com/).
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Asia/Ho_Chi_Minh

# --- Community nodes (packages) — version-control tại đây ------------------
# JSON array. Thêm/bớt package ở đây rồi `docker compose up -d` lại,
# n8n tự đồng bộ khi khởi động.
#
#   Ví dụ có node:
#     N8N_COMMUNITY_PACKAGES=[{"name":"n8n-nodes-mcp","version":"0.1.20"}]
#   Nhiều node:
#     N8N_COMMUNITY_PACKAGES=[{"name":"n8n-nodes-mcp","version":"0.1.20"},{"name":"n8n-nodes-comfyui","version":"1.0.4"}]
#
# ⚠️ Vì compose bật MANAGED_BY_ENV=true: lần đầu khởi động, n8n sẽ GỠ mọi
#    community node đang cài mà KHÔNG có trong list này. Nếu bạn đã cài node
#    qua UI từ trước, liệt kê hết chúng vào đây TRƯỚC khi chạy.
#    Chưa có node nào → để mảng rỗng:
N8N_COMMUNITY_PACKAGES=[]
